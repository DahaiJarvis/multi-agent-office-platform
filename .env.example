# ==================== LLM 配置 ====================
# 阿里云通义千问 API（兼容 OpenAI 接口格式）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置
MODEL_QWEN_MAX=qwen-max
MODEL_QWEN_PLUS=qwen-plus
MODEL_QWEN_TURBO=qwen-turbo

# ==================== 数据库配置 ====================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 可观测性配置 ====================
# Langfuse
LANGFUSE_PUBLIC_KEY=pk-your-langfuse-public-key
LANGFUSE_SECRET_KEY=sk-your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=multi-agent-office-platform

# ==================== API 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO
ENVIRONMENT=development

# ==================== 安全配置 ====================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ==================== SSO 企业身份集成 ====================
# SSO 总开关
SSO_ENABLED=false

# Microsoft Entra ID (Azure AD)
SSO_ENTRA_ID_ENABLED=false
SSO_ENTRA_ID_CLIENT_ID=
SSO_ENTRA_ID_CLIENT_SECRET=
SSO_ENTRA_ID_TENANT_ID=common
SSO_ENTRA_ID_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# Okta
SSO_OKTA_ENABLED=false
SSO_OKTA_CLIENT_ID=
SSO_OKTA_CLIENT_SECRET=
SSO_OKTA_DOMAIN=your-domain.okta.com
SSO_OKTA_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# 企业微信
SSO_WECOM_ENABLED=false
SSO_WECOM_CORP_ID=
SSO_WECOM_AGENT_ID=
SSO_WECOM_SECRET=
SSO_WECOM_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# 钉钉
SSO_DINGTALK_ENABLED=false
SSO_DINGTALK_CLIENT_ID=
SSO_DINGTALK_CLIENT_SECRET=
SSO_DINGTALK_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# 飞书
SSO_FEISHU_ENABLED=false
SSO_FEISHU_APP_ID=
SSO_FEISHU_APP_SECRET=
SSO_FEISHU_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# ==================== 静态数据加密 ====================
# 加密总开关
ENCRYPTION_ENABLED=true
# 密钥提供者类型: auto/local/env
ENCRYPTION_KEY_PROVIDER=auto
# 本地密钥文件路径（local 模式）
ENCRYPTION_KEY_FILE=
# 主密钥（env 模式，base64 编码的 32 字节密钥）
ENCRYPTION_MASTER_KEY=

# ==================== 数据驻留控制 ====================
# 当前部署区域: cn-north/cn-east/cn-south/eu-west/eu-central/us-east/us-west/ap-southeast
DATA_RESIDENCY_REGION=cn-north
# 是否强制执行数据驻留策略
DATA_RESIDENCY_ENFORCED=true

# ==================== 多租户配置 ====================
# 多租户总开关
MULTI_TENANT_ENABLED=false
# 默认隔离级别: row/schema/database
TENANT_DEFAULT_ISOLATION=row
# 默认数据区域
TENANT_DEFAULT_REGION=cn-north

# ==================== MCP 服务配置 ====================
# OA 系统
OA_API_URL=http://localhost:3001/api
OA_API_TOKEN=your-oa-api-token
OA_API_TIMEOUT=10.0

# 邮件系统
EMAIL_API_URL=http://localhost:3002/api
EMAIL_API_TOKEN=your-email-api-token
EMAIL_API_TIMEOUT=10.0

# 日历系统
CALENDAR_API_URL=http://localhost:3003/api
CALENDAR_API_TOKEN=your-calendar-api-token
CALENDAR_API_TIMEOUT=10.0

# CRM 系统
CRM_API_URL=http://localhost:3004/api
CRM_API_TOKEN=your-crm-api-token
CRM_API_TIMEOUT=10.0

# MCP 注册中心
MCP_REGISTRY_HOST=0.0.0.0
MCP_REGISTRY_PORT=9099

# ==================== 限流配置 ====================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100
