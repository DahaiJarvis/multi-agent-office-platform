# ==================== LLM 配置 ====================
# 阿里云通义千问 API（兼容 OpenAI 接口格式）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置
MODEL_QWEN_MAX=qwen-max
MODEL_QWEN_PLUS=qwen-plus
MODEL_QWEN_TURBO=qwen-turbo

# ==================== 数据库配置 ====================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 可观测性配置 ====================
# Langfuse
LANGFUSE_PUBLIC_KEY=pk-your-langfuse-public-key
LANGFUSE_SECRET_KEY=sk-your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=multi-agent-office-platform

# ==================== API 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO
ENVIRONMENT=development

# ==================== 安全配置 ====================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ==================== MCP 服务配置 ====================
# OA 系统
OA_API_URL=http://localhost:3001/api
OA_API_TOKEN=your-oa-api-token

# 邮件系统
EMAIL_API_URL=http://localhost:3002/api
EMAIL_API_TOKEN=your-email-api-token

# 日历系统
CALENDAR_API_URL=http://localhost:3003/api
CALENDAR_API_TOKEN=your-calendar-api-token

# CRM 系统
CRM_API_URL=http://localhost:3004/api
CRM_API_TOKEN=your-crm-api-token

# ==================== 限流配置 ====================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100
